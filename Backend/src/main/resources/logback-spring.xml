<?xml version="1.0" encoding="UTF-8"?>
<!--
  Ember 백엔드 Logback 설정 (M7 관측성 + §13.5 로그 마스킹)

  프로파일별 인코더 전략:
    - prod    : LogstashEncoder (JSON) + MaskingConverter 적용
    - local / dev / 기타 : MaskingPatternLayout (사람이 읽기 좋은 출력 + 마스킹)

  MDC 필드 (LogstashEncoder가 자동으로 JSON 필드로 포함):
    - requestId   : RequestTraceFilter에서 주입 (X-Request-ID 헤더)
    - traceId     : Micrometer Tracing 자동 주입
    - spanId      : Micrometer Tracing 자동 주입
    - outboxEventId : OutboxRelay.processEvent 에서 주입
    - eventType   : OutboxRelay.processEvent 에서 주입
    - messageId   : OutboxRelay.processDiaryAnalyzeRequested 등에서 주입

  §13.5 마스킹 대상:
    - Access Token  → eyJhbGci...[MASKED]
    - Refresh Token → [REFRESH_TOKEN_MASKED]
    - 이메일        → us***@example.com
    - 실명          → 김**
    - 전화번호      → 010-****-****
    - 일기/채팅 본문 → [CONTENT_MASKED]
-->
<configuration>

  <!-- ── 공통 속성 ────────────────────────────────────────────────────────── -->
  <springProperty scope="context" name="appName"
      source="management.metrics.tags.application"
      defaultValue="ember-backend"/>

  <!-- ── prod 프로파일: Logstash JSON 인코더 + 파일 로그 ──────────────────── -->
  <springProfile name="prod">
    <!-- 콘솔 출력 (JSON) -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <customFields>{"app":"${appName}"}</customFields>
        <includeMdcKeyName>requestId</includeMdcKeyName>
        <includeMdcKeyName>traceId</includeMdcKeyName>
        <includeMdcKeyName>spanId</includeMdcKeyName>
        <includeMdcKeyName>outboxEventId</includeMdcKeyName>
        <includeMdcKeyName>eventType</includeMdcKeyName>
        <includeMdcKeyName>messageId</includeMdcKeyName>
        <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'+09:00'</timestampPattern>
        <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
          <maxDepthPerCause>10</maxDepthPerCause>
          <maxLength>8192</maxLength>
          <rootCauseFirst>true</rootCauseFirst>
        </throwableConverter>
      </encoder>
    </appender>

    <!-- 파일 로그 (§13.5 마스킹 적용, 30일 보관) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <file>/app/logs/ember.log</file>
      <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
        <fileNamePattern>/app/logs/ember_%d{yyyyMMdd}.log</fileNamePattern>
        <maxHistory>30</maxHistory>
        <totalSizeCap>1GB</totalSizeCap>
      </rollingPolicy>
      <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
        <layout class="com.ember.ember.global.logging.MaskingPatternLayout">
          <pattern>%d{yyyy.MM.dd HH:mm:ss.SS} [%-5level] %msg%n</pattern>
        </layout>
        <charset>UTF-8</charset>
      </encoder>
    </appender>

    <root level="INFO">
      <appender-ref ref="STDOUT"/>
      <appender-ref ref="FILE"/>
    </root>
  </springProfile>

  <!-- ── local / dev 프로파일: 마스킹 패턴 인코더 ────────────────────────── -->
  <springProfile name="local,dev">
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
        <layout class="com.ember.ember.global.logging.MaskingPatternLayout">
          <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level [%X{traceId:--}/%X{spanId:--}] %logger{36} - %msg%n</pattern>
        </layout>
        <charset>UTF-8</charset>
      </encoder>
    </appender>

    <!-- SQL 로그는 DEBUG 레벨에서만 표시 (개발 편의) -->
    <logger name="org.hibernate.SQL" level="DEBUG"/>
    <logger name="org.hibernate.orm.jdbc.bind" level="TRACE"/>

    <root level="DEBUG">
      <appender-ref ref="STDOUT"/>
    </root>
  </springProfile>

  <!-- ── 기타 프로파일(미지정): 기본 마스킹 인코더 ───────────────────────── -->
  <springProfile name="!prod,!local,!dev">
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
        <layout class="com.ember.ember.global.logging.MaskingPatternLayout">
          <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </layout>
        <charset>UTF-8</charset>
      </encoder>
    </appender>

    <root level="INFO">
      <appender-ref ref="STDOUT"/>
    </root>
  </springProfile>

</configuration>
